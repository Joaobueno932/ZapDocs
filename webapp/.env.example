# Copy this file to .env and fill in the values before running.
# NEVER commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────

# Flask session secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-this-to-a-random-string

# Admin password (set a strong password before deploying)
ADMIN_PASS=change-this-to-a-strong-password

# ── Optional ──────────────────────────────────────────────────────────────────

# Admin username (default: admin)
# ADMIN_USER=admin

# Database URL (default: SQLite file in webapp/users.db)
# For production on Render, paste the PostgreSQL Internal Database URL:
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Temporary file directory (default: webapp/temp_jobs)
# On Render with a Persistent Disk mounted at /var/data, set:
# TEMP_DIR=/var/data/temp_jobs

# Hours to keep generated PDFs before auto-deletion (default: 24)
# JOB_RETENTION_HOURS=24

# Max upload size in MB (default: 500)
# MAX_CONTENT_LENGTH_MB=500

# Set to 'production' to enable secure (HTTPS-only) session cookies on Render
# FLASK_ENV=production

# Redis URL for cross-worker rate limiting (optional; without it, limits are per-worker)
# REDIS_URL=redis://localhost:6379

# Port (default: 5000 for local dev; Render sets this automatically)
# PORT=5000
